<?xml version="1.0" encoding="utf-8"?>
<!--
    Drawable referenced ONLY via ui_config.json asset file.
    No direct R.drawable.feature_banner reference exists in code.
    With shrinkResources + strict mode, aapt2 removes this resource.
    Fix: Add tools:keep="@drawable/feature_banner" in res/raw/keep.xml
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#667eea"
        android:endColor="#764ba2"
        android:angle="135" />
    <corners android:radius="12dp" />
</shape>
